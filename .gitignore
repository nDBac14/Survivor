# ==========================================================
#  .gitignore cho dự án Unity
#  Đặt file này ở THƯ MỤC GỐC của project (ngang hàng Assets/)
# ==========================================================

# --- Thư mục Unity tự sinh (KHÔNG đẩy lên) ---
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/

# Asset meta data chỉ nên bỏ qua khi thư mục cha bị bỏ qua
!/[Aa]ssets/**/*.meta

# --- Bản build cho Android / nền tảng khác ---
*.apk
*.aab
*.unitypackage
*.app

# --- File IDE / editor tự sinh ---
/.vs/
/.idea/
/.vscode/
/.gradle/
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# --- Crash & log Unity ---
sysinfo.txt
crashlytics-build.properties

# --- File rác hệ điều hành ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Bộ nhớ đệm gói / công cụ ---
/[Aa]ssets/[Aa]ssetStoreTools*
/[Aa]ssets/Plugins/Editor/JetBrains*